<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.collections.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.spring26.section2.group17.bangladeshbank.Towhid.CyberSecurityOfficer.ManageUserAccessViolationsController"
            prefHeight="400.0" prefWidth="600.0">

    <!-- Title -->
    <Label layoutX="20.0" layoutY="10.0" text="Manage User Access Violations"
           style="-fx-font-size: 18px; -fx-font-weight: bold;" />

    <!-- Violations Table -->
    <Label layoutX="20.0" layoutY="40.0" text="Access Violations:" />
    <TableView fx:id="violationTable" layoutX="20.0" layoutY="60.0"
               prefHeight="140.0" prefWidth="560.0">

        <columns>
            <TableColumn fx:id="userIdColumn" text="User ID" prefWidth="180"/>
            <TableColumn fx:id="violationTypeColumn" text="Violation Type" prefWidth="200"/>
            <TableColumn fx:id="dateColumn" text="Date" prefWidth="180"/>
        </columns>
    </TableView>

    <!-- Restrict Button -->
    <Button fx:id="restrictButton" layoutX="450.0" layoutY="210.0"
            text="Restrict Access" prefWidth="130"/>

    <!-- Restriction Details Section -->
    <Label layoutX="20.0" layoutY="240.0"
           text="Restriction Details:" style="-fx-font-weight: bold;" />

    <GridPane layoutX="20.0" layoutY="260.0" hgap="10" vgap="10">

        <!-- Selected User -->
        <Label text="User ID:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <TextField fx:id="userIdField" promptText="Selected user ID"
                   GridPane.rowIndex="0" GridPane.columnIndex="1"/>

        <!-- Restriction Type -->
        <Label text="Restriction Type:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <HBox spacing="10" GridPane.rowIndex="1" GridPane.columnIndex="1">
            <RadioButton fx:id="temporaryRadio" text="Temporary" toggleGroup="$restrictionGroup"/>
            <RadioButton fx:id="permanentRadio" text="Permanent" toggleGroup="$restrictionGroup"/>
        </HBox>

        <!-- Duration -->
        <Label text="Duration:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <ComboBox fx:id="durationComboBox" GridPane.rowIndex="2" GridPane.columnIndex="1">
            <items>
                <FXCollections fx:factory="observableArrayList">
                    <String fx:value="1 Day"/>
                    <String fx:value="7 Days"/>
                    <String fx:value="30 Days"/>
                    <String fx:value="Indefinite"/>
                </FXCollections>
            </items>
        </ComboBox>

        <!-- Officer Password -->
        <Label text="Officer Password:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
        <PasswordField fx:id="passwordField" promptText="Enter password"
                       GridPane.rowIndex="3" GridPane.columnIndex="1"/>

        <!-- Notes -->
        <Label text="Notes:" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
        <TextArea fx:id="notesArea" promptText="Enter reason for restriction..."
                  prefRowCount="3" GridPane.rowIndex="4" GridPane.columnIndex="1"/>
    </GridPane>

    <!-- Action Buttons -->
    <Button fx:id="applyButton" layoutX="350.0" layoutY="360.0"
            text="Apply Restriction" prefWidth="120"/>

    <Button fx:id="clearButton" layoutX="480.0" layoutY="360.0"
            text="Clear" prefWidth="100"/>

</AnchorPane>
