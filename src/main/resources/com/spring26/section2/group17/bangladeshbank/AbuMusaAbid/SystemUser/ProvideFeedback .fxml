<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.spring26.section2.group17.bangladeshbank.AbuMusaAbid.SystemUser.ProvideFeedbackController"
            prefHeight="400.0" prefWidth="600.0">

    <!-- Title -->
    <Label layoutX="220.0" layoutY="10.0"
           text="Provide Feedback"
           style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

    <!-- Name (Optional) -->
    <Label layoutX="50.0" layoutY="60.0" text="Name (Optional):"/>
    <TextField fx:id="nameField" layoutX="180.0" layoutY="55.0" prefWidth="250.0"/>

    <!-- Email / Contact -->
    <Label layoutX="50.0" layoutY="100.0" text="Email / Contact:"/>
    <TextField fx:id="emailField" layoutX="180.0" layoutY="95.0" prefWidth="250.0"/>

    <!-- Feedback Message -->
    <Label layoutX="50.0" layoutY="140.0" text="Feedback:"/>
    <TextArea fx:id="feedbackArea" layoutX="180.0" layoutY="135.0"
              prefWidth="300.0" prefHeight="120.0"/>

    <!-- Submit Button -->
    <Button fx:id="submitButton" layoutX="180.0" layoutY="280.0"
            text="Submit" prefWidth="100.0"/>

    <!-- Confirmation Message -->
    <Label fx:id="confirmationLabel" layoutX="300.0" layoutY="285.0"
           text="" style="-fx-text-fill: green;"/>

</AnchorPane>