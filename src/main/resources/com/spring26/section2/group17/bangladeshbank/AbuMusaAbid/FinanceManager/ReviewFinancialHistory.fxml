<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="450.0" prefWidth="650.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.spring26.section2.group17.bangladeshbank.AbuMusaAbid.FinanceManager.ReviewFinancialHistoryController">

    <Label layoutX="200.0" layoutY="10.0" style="-fx-font-size: 18px; -fx-font-weight: bold;" text="Financial History" />

    <Label layoutX="40.0" layoutY="60.0" text="From Date:" />
    <TextField fx:id="fromDateField" layoutX="120.0" layoutY="55.0" prefWidth="120.0" />

    <Label layoutX="260.0" layoutY="60.0" text="To Date:" />
    <TextField fx:id="toDateField" layoutX="330.0" layoutY="55.0" prefWidth="120.0" />

    <Label layoutX="470.0" layoutY="60.0" text="Type:" />
    <ComboBox fx:id="typeComboBox" layoutX="520.0" layoutY="55.0" prefWidth="110.0" />

    <Button fx:id="searchButton" layoutX="520.0" layoutY="90.0" prefWidth="110.0" text="Search" />

    <TableView fx:id="historyTable" layoutX="40.0" layoutY="130.0" prefHeight="220.0" prefWidth="590.0">

        <columns>
            <TableColumn fx:id="transactionIdColumn" prefWidth="150.0" text="Transaction ID" />
            <TableColumn fx:id="amountColumn" prefWidth="120.0" text="Amount" />
            <TableColumn fx:id="dateColumn" prefWidth="150.0" text="Date" />
            <TableColumn fx:id="typeColumn" prefWidth="150.0" text="Type" />
        </columns>

    </TableView>

    <Label fx:id="statusLabel" layoutX="40.0" layoutY="370.0" style="-fx-text-fill: green;" text="" />
   <Button layoutX="536.0" layoutY="387.0" mnemonicParsing="false" onAction="#BackButton" text="Back" />

</AnchorPane>
