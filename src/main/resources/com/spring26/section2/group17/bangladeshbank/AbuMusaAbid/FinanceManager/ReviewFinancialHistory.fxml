<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.spring26.section2.group17.bangladeshbank.AbuMusaAbid.FinanceManager.ReviewFinancialHistoryController"
            prefHeight="450.0" prefWidth="650.0">

    <!-- Title -->
    <Label layoutX="200.0" layoutY="10.0"
           text="Financial History"
           style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

    <!-- Filters -->
    <Label layoutX="40.0" layoutY="60.0" text="From Date:"/>
    <TextField fx:id="fromDateField"
               layoutX="120.0" layoutY="55.0"
               prefWidth="120.0"/>

    <Label layoutX="260.0" layoutY="60.0" text="To Date:"/>
    <TextField fx:id="toDateField"
               layoutX="330.0" layoutY="55.0"
               prefWidth="120.0"/>

    <Label layoutX="470.0" layoutY="60.0" text="Type:"/>
    <ComboBox fx:id="typeComboBox"
              layoutX="520.0" layoutY="55.0"
              prefWidth="110.0"/>

    <Button fx:id="searchButton"
            layoutX="520.0" layoutY="90.0"
            text="Search"
            prefWidth="110.0"/>

    <!-- Table -->
    <TableView fx:id="historyTable"
               layoutX="40.0" layoutY="130.0"
               prefWidth="590.0" prefHeight="220.0">

        <columns>
            <TableColumn fx:id="transactionIdColumn" text="Transaction ID" prefWidth="150.0"/>
            <TableColumn fx:id="amountColumn" text="Amount" prefWidth="120.0"/>
            <TableColumn fx:id="dateColumn" text="Date" prefWidth="150.0"/>
            <TableColumn fx:id="typeColumn" text="Type" prefWidth="150.0"/>
        </columns>

    </TableView>

    <!-- Status Message -->
    <Label fx:id="statusLabel"
           layoutX="40.0" layoutY="370.0"
           text=""
           style="-fx-text-fill: green;"/>

</AnchorPane>