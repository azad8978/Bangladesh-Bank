<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="452.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.spring26.section2.group17.bangladeshbank.AbuMusaAbid.SystemUser.MonitorTaskAssignmentsController">

    <!-- Title -->
    <Label layoutX="200.0" layoutY="10.0" style="-fx-font-size: 18px; -fx-font-weight: bold;" text="Monitor Task Assignments" />

    <!-- TableView for Tasks -->
    <TableView fx:id="taskTable" layoutX="50.0" layoutY="50.0" prefHeight="200.0" prefWidth="500.0">
        <columns>
            <TableColumn fx:id="taskIdColumn" prefWidth="100.0" text="Task ID" />
            <TableColumn fx:id="descriptionColumn" prefWidth="200.0" text="Description" />
            <TableColumn fx:id="statusColumn" prefWidth="100.0" text="Status" />
            <TableColumn fx:id="deadlineColumn" prefWidth="100.0" text="Deadline" />
        </columns>
    </TableView>

    <!-- Task Details Label -->
    <Label layoutX="50.0" layoutY="270.0" text="Task Details:" />

    <!-- TextArea to show detailed task info -->
    <TextArea fx:id="taskDetailsArea" editable="false" layoutX="50.0" layoutY="290.0" prefHeight="90.0" prefWidth="500.0" />
   <Button fx:id="BackButton" layoutX="259.0" layoutY="404.0" mnemonicParsing="false" text="Back" />

</AnchorPane>
