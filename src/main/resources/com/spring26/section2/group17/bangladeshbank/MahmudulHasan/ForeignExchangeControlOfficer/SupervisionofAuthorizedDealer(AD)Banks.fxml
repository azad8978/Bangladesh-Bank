<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.spring26.section2.group17.bangladeshbank.MahmudulHasan.ForeignExchangeControlOfficer.SupervisionofAuthorizedDealerADBanksController">
    <children>

        <!-- HEADER -->
        <Label layoutX="95.0" layoutY="14.0" style="-fx-font-size: 20px; -fx-font-weight: bold;" text="Authorized Dealer (AD) Bank Supervision System" />

        <!-- EVENT 1: ACCESS PORTAL -->
        <HBox layoutX="20" layoutY="50" prefHeight="26.0" prefWidth="276.0" spacing="15">
            <children>
                <Label prefHeight="24.0" prefWidth="180.0" text="Access AD Bank Control Module:" />
                <Button fx:id="btnOpenPortal" text="Open Portal" />
            </children>
        </HBox>

        <!-- LEFT SIDE: INPUT SECTION (EVENT 2) -->
        <VBox layoutX="20" layoutY="100" prefHeight="220" prefWidth="260" spacing="10" style="-fx-border-color: #BDC3C7; -fx-padding: 10;">

            <children>
                <Label style="-fx-font-weight: bold;" text="Bank FX Data Entry" />

                <TextField fx:id="bankNameField" promptText="Bank Name" />
                <TextField fx:id="licenseField" promptText="License Number" />
                <TextField fx:id="transactionVolumeField" promptText="Transaction Volume" />
                <TextField fx:id="reportField" promptText="Report Summary" />

                <Button fx:id="btnSubmit" text="Submit Data" />
            </children>

        </VBox>

        <!-- RIGHT SIDE: VERIFICATION + RESULT -->
        <VBox layoutX="320" layoutY="100" prefHeight="220" prefWidth="260" spacing="15" style="-fx-border-color: #BDC3C7; -fx-padding: 10;">

            <children>

                <!-- EVENT 3 -->
                <Label style="-fx-font-weight: bold;" text="License Compliance Check" />

                <Button fx:id="btnVerify" text="Verify Compliance" />

                <CheckBox fx:id="licenseCheck" text="Valid License" />
                <CheckBox fx:id="regulationCheck" text="Regulatory Compliance" />

                <!-- EVENT 4 -->
                <Label text="Compliance Status:" />

                <Label fx:id="statusLabel" style="-fx-font-size: 14px;" text="Pending" />

            </children>

        </VBox>

        <!-- EVENT 5: TABLE (BOTTOM) -->
        <TableView fx:id="reportTable" layoutX="20" layoutY="340" prefHeight="180" prefWidth="560">

            <columns>
                <TableColumn fx:id="colBank" text="Bank Name" />
                <TableColumn fx:id="colLicense" text="License" />
                <TableColumn fx:id="colVolume" text="Volume" />
                <TableColumn fx:id="colStatus" text="Status" />
            </columns>

        </TableView>

    </children>

</AnchorPane>
