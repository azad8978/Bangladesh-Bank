<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.collections.FXCollections?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.spring26.section2.group17.bangladeshbank.Towhid.DataAnalyst.GenerateStatisticalSummariesController">

    <!-- Title -->
    <Label layoutX="20.0" layoutY="10.0" style="-fx-font-size:18px; -fx-font-weight:bold;" text="Generate Statistical Summaries" />

    <!-- Statistics Button -->
    <Button fx:id="statsButton" layoutX="450.0" layoutY="10.0" prefWidth="120" text="Statistics" />

    <!-- Metric Selection -->
    <Label layoutX="20.0" layoutY="50.0" style="-fx-font-weight:bold;" text="Select Metrics:" />

    <VBox layoutX="20.0" layoutY="80.0" spacing="10">

        <CheckBox fx:id="meanCheckBox" text="Mean" />
        <CheckBox fx:id="medianCheckBox" text="Median" />
        <CheckBox fx:id="modeCheckBox" text="Mode" />
        <CheckBox fx:id="stdDevCheckBox" text="Standard Deviation" />

    </VBox>

    <!-- Data Type Selection -->
    <Label layoutX="200.0" layoutY="50.0" text="Data Type:" />
    <ComboBox fx:id="dataTypeComboBox" layoutX="200.0" layoutY="70.0">
        <items>
            <FXCollections fx:factory="observableArrayList">
                <String fx:value="Numeric" />
                <String fx:value="Categorical" />
                <String fx:value="Time Series" />
            </FXCollections>
        </items>
    </ComboBox>

    <!-- Input Data -->
    <Label layoutX="20.0" layoutY="200.0" text="Input Data:" />
    <TextArea fx:id="inputDataArea" layoutX="20.0" layoutY="220.0" prefHeight="60.0" prefWidth="560.0" promptText="Enter data (e.g., 10, 20, 30...)" />

    <!-- Result Area -->
    <Label layoutX="20.0" layoutY="290.0" style="-fx-font-weight:bold;" text="Statistical Summary:" />

    <TextArea fx:id="resultArea" layoutX="20.0" layoutY="310.0" prefHeight="60.0" prefWidth="560.0" promptText="Results will be displayed here..." />

    <!-- Generate Button -->
    <Button fx:id="generateButton" layoutX="450.0" layoutY="380.0" prefWidth="120" text="Generate" />
   <Button layoutX="406.0" layoutY="70.0" mnemonicParsing="false" onAction="#ButtonOA" text="BackButton " />

</AnchorPane>
