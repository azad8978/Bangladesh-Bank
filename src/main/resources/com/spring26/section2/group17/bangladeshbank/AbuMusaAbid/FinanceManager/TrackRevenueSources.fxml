<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.spring26.section2.group17.bangladeshbank.AbuMusaAbid.FinanceManager.TrackRevenueSourcesController"
            prefHeight="450.0" prefWidth="650.0">

    <!-- Title -->
    <Label layoutX="200.0" layoutY="10.0"
           text="Revenue Tracking"
           style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

    <!-- Filter Section -->
    <Label layoutX="40.0" layoutY="60.0" text="Source:"/>
    <ComboBox fx:id="sourceComboBox"
              layoutX="100.0" layoutY="55.0"
              prefWidth="150.0"/>

    <Label layoutX="270.0" layoutY="60.0" text="From Date:"/>
    <TextField fx:id="fromDateField"
               layoutX="350.0" layoutY="55.0"
               prefWidth="100.0"/>

    <Label layoutX="470.0" layoutY="60.0" text="To Date:"/>
    <TextField fx:id="toDateField"
               layoutX="530.0" layoutY="55.0"
               prefWidth="100.0"/>

    <Button fx:id="filterButton"
            layoutX="530.0" layoutY="90.0"
            text="Filter"
            prefWidth="100.0"/>

    <!-- Revenue Table -->
    <TableView fx:id="revenueTable"
               layoutX="40.0" layoutY="130.0"
               prefWidth="590.0" prefHeight="220.0">

        <columns>
            <TableColumn fx:id="sourceNameColumn" text="Source Name" prefWidth="200.0"/>
            <TableColumn fx:id="amountColumn" text="Amount" prefWidth="150.0"/>
            <TableColumn fx:id="dateColumn" text="Date" prefWidth="200.0"/>
        </columns>

    </TableView>

    <!-- Summary -->
    <Label layoutX="40.0" layoutY="370.0" text="Total Revenue:"/>
    <Label fx:id="totalRevenueLabel"
           layoutX="150.0" layoutY="370.0"
           text="0.00"
           style="-fx-font-weight: bold;"/>

</AnchorPane>