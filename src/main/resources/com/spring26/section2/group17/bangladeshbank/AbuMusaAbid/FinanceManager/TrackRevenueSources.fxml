<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="450.0" prefWidth="650.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.spring26.section2.group17.bangladeshbank.AbuMusaAbid.FinanceManager.TrackRevenueSourcesController">

    <Label layoutX="200.0" layoutY="10.0" style="-fx-font-size: 18px; -fx-font-weight: bold;" text="Revenue Tracking" />

    <Label layoutX="40.0" layoutY="60.0" text="Source:" />
    <ComboBox fx:id="sourceComboBox" layoutX="100.0" layoutY="55.0" prefWidth="150.0" />

    <Label layoutX="270.0" layoutY="60.0" text="From Date:" />
    <TextField fx:id="fromDateField" layoutX="350.0" layoutY="55.0" prefWidth="100.0" />

    <Label layoutX="470.0" layoutY="60.0" text="To Date:" />
    <TextField fx:id="toDateField" layoutX="530.0" layoutY="55.0" prefWidth="100.0" />

    <Button fx:id="filterButton" layoutX="530.0" layoutY="90.0" prefWidth="100.0" text="Filter" />

    <TableView fx:id="revenueTable" layoutX="40.0" layoutY="130.0" prefHeight="220.0" prefWidth="590.0">

        <columns>
            <TableColumn fx:id="sourceNameColumn" prefWidth="200.0" text="Source Name" />
            <TableColumn fx:id="amountColumn" prefWidth="150.0" text="Amount" />
            <TableColumn fx:id="dateColumn" prefWidth="200.0" text="Date" />
        </columns>

    </TableView>

    <Label layoutX="40.0" layoutY="370.0" text="Total Revenue:" />
    <Label fx:id="totalRevenueLabel" layoutX="150.0" layoutY="370.0" style="-fx-font-weight: bold;" text="0.00" />
   <Button layoutX="553.0" layoutY="375.0" mnemonicParsing="false" onAction="#BackButton" text="Back" />

</AnchorPane>
