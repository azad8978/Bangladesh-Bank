<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.collections.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.spring26.section2.group17.bangladeshbank.Towhid.CyberSecurityOfficer.MonitorSystemSecurityStatusController"
            prefHeight="400.0" prefWidth="600.0">

    <!-- Title -->
    <Label layoutX="20.0" layoutY="10.0"
           text="Security Dashboard"
           style="-fx-font-size:18px; -fx-font-weight:bold;" />

    <!-- Security Overview -->
    <Label layoutX="20.0" layoutY="50.0"
           text="Security Overview:" style="-fx-font-weight:bold;" />

    <GridPane layoutX="20.0" layoutY="70.0" hgap="10" vgap="10">

        <!-- Threat Level -->
        <Label text="Threat Level:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <TextField fx:id="threatLevelField"
                   promptText="Low / Medium / High"
                   GridPane.rowIndex="0" GridPane.columnIndex="1"/>

        <!-- Active Alerts -->
        <Label text="Active Alerts:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <TextField fx:id="alertsField"
                   promptText="Enter alert count"
                   GridPane.rowIndex="1" GridPane.columnIndex="1"/>

        <!-- System Health -->
        <Label text="System Health:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <ComboBox fx:id="healthComboBox"
                  GridPane.rowIndex="2" GridPane.columnIndex="1">
            <items>
                <FXCollections fx:factory="observableArrayList">
                    <String fx:value="Good"/>
                    <String fx:value="Warning"/>
                    <String fx:value="Critical"/>
                </FXCollections>
            </items>
        </ComboBox>

    </GridPane>

    <!-- Time Range Selection -->
    <Label layoutX="20.0" layoutY="160.0"
           text="Select Time Range:" style="-fx-font-weight:bold;" />

    <HBox layoutX="20.0" layoutY="180.0" spacing="15">
        <RadioButton fx:id="todayRadio" text="Today" toggleGroup="$timeGroup"/>
        <RadioButton fx:id="weekRadio" text="Last 7 Days" toggleGroup="$timeGroup"/>
        <RadioButton fx:id="monthRadio" text="Last 30 Days" toggleGroup="$timeGroup"/>
    </HBox>

    <!-- Extra Range Option -->
    <Label layoutX="20.0" layoutY="220.0" text="Custom Range:" />
    <ComboBox fx:id="customRangeBox" layoutX="120.0" layoutY="215.0">
        <items>
            <FXCollections fx:factory="observableArrayList">
                <String fx:value="Last 24 Hours"/>
                <String fx:value="Last 3 Days"/>
                <String fx:value="Last 6 Months"/>
            </FXCollections>
        </items>
    </ComboBox>

    <!-- Dashboard Output -->
    <Label layoutX="20.0" layoutY="260.0"
           text="Dashboard Output:" style="-fx-font-weight:bold;" />

    <TextArea fx:id="dashboardArea"
              layoutX="20.0" layoutY="280.0"
              prefWidth="560.0" prefHeight="60.0"
              promptText="Updated data will appear here..." />

    <!-- Update Button -->
    <Button fx:id="updateButton"
            layoutX="460.0" layoutY="350.0"
            text="Update"
            prefWidth="100"/>

</AnchorPane>