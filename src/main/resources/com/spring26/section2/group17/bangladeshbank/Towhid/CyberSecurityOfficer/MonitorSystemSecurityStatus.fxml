<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.collections.FXCollections?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.spring26.section2.group17.bangladeshbank.Towhid.CyberSecurityOfficer.MonitorSystemSecurityStatusController">

    <!-- Title -->
    <Label layoutX="20.0" layoutY="10.0" style="-fx-font-size:18px; -fx-font-weight:bold;" text="Security Dashboard" />

    <!-- Security Overview -->
    <Label layoutX="20.0" layoutY="50.0" style="-fx-font-weight:bold;" text="Security Overview:" />

    <GridPane hgap="10" layoutX="20.0" layoutY="70.0" vgap="10">

        <!-- Threat Level -->
        <Label text="Threat Level:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
        <TextField fx:id="threatLevelField" promptText="Low / Medium / High" GridPane.columnIndex="1" GridPane.rowIndex="0" />

        <!-- Active Alerts -->
        <Label text="Active Alerts:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
        <TextField fx:id="alertsField" promptText="Enter alert count" GridPane.columnIndex="1" GridPane.rowIndex="1" />

        <!-- System Health -->
        <Label text="System Health:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
        <ComboBox fx:id="healthComboBox" GridPane.columnIndex="1" GridPane.rowIndex="2">
            <items>
                <FXCollections fx:factory="observableArrayList">
                    <String fx:value="Good" />
                    <String fx:value="Warning" />
                    <String fx:value="Critical" />
                </FXCollections>
            </items>
        </ComboBox>
      <columnConstraints>
         <ColumnConstraints />
         <ColumnConstraints />
      </columnConstraints>
      <rowConstraints>
         <RowConstraints />
         <RowConstraints />
         <RowConstraints />
      </rowConstraints>

    </GridPane>

    <!-- Time Range Selection -->
    <Label layoutX="20.0" layoutY="160.0" style="-fx-font-weight:bold;" text="Select Time Range:" />

    <HBox layoutX="20.0" layoutY="180.0" spacing="15">
        <RadioButton fx:id="todayRadio" text="Today">
         <toggleGroup>
            <ToggleGroup fx:id="timeGroup" />
         </toggleGroup></RadioButton>
        <RadioButton fx:id="weekRadio" text="Last 7 Days" toggleGroup="$timeGroup" />
        <RadioButton fx:id="monthRadio" text="Last 30 Days" toggleGroup="$timeGroup" />
    </HBox>

    <!-- Extra Range Option -->
    <Label layoutX="20.0" layoutY="220.0" text="Custom Range:" />
    <ComboBox fx:id="customRangeBox" layoutX="120.0" layoutY="215.0">
        <items>
            <FXCollections fx:factory="observableArrayList">
                <String fx:value="Last 24 Hours" />
                <String fx:value="Last 3 Days" />
                <String fx:value="Last 6 Months" />
            </FXCollections>
        </items>
    </ComboBox>

    <!-- Dashboard Output -->
    <Label layoutX="20.0" layoutY="260.0" style="-fx-font-weight:bold;" text="Dashboard Output:" />

    <TextArea fx:id="dashboardArea" layoutX="20.0" layoutY="280.0" prefHeight="60.0" prefWidth="560.0" promptText="Updated data will appear here..." />

    <!-- Update Button -->
    <Button layoutX="460.0" layoutY="350.0" onAction="#update" prefWidth="100" text="Update" />
   <Button layoutX="333.0" layoutY="350.0" mnemonicParsing="false" onAction="#ButtonOA" text="BackButton" />

</AnchorPane>
