<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="486.0" prefWidth="650.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.spring26.section2.group17.bangladeshbank.AbuMusaAbid.FinanceManager.MonitorExpendituresController">

    <Label layoutX="220.0" layoutY="10.0" style="-fx-font-size: 18px; -fx-font-weight: bold;" text="Monitor Expenditures" />

    <TableView fx:id="expenditureTable" layoutX="30.0" layoutY="50.0" prefHeight="200.0" prefWidth="590.0">
        <columns>
            <TableColumn fx:id="transactionIdColumn" prefWidth="110.0" text="Transaction ID" />
            <TableColumn fx:id="departmentColumn" prefWidth="120.0" text="Department" />
            <TableColumn fx:id="amountColumn" prefWidth="100.0" text="Amount" />
            <TableColumn fx:id="dateColumn" prefWidth="110.0" text="Date" />
            <TableColumn fx:id="recordedByColumn" prefWidth="150.0" text="Recorded By" />
        </columns>
    </TableView>

    <Label layoutX="30.0" layoutY="270.0" text="Transaction Details:" />


    <TextArea fx:id="detailsArea" editable="false" layoutX="30.0" layoutY="290.0" prefHeight="80.0" prefWidth="590.0" />

    <Label layoutX="30.0" layoutY="380.0" text="Payment Method:" />
    <TextField fx:id="paymentMethodField" editable="false" layoutX="140.0" layoutY="375.0" prefWidth="150.0" />

    <Label layoutX="310.0" layoutY="380.0" text="Linked Budget:" />
    <TextField fx:id="budgetField" editable="false" layoutX="420.0" layoutY="375.0" prefWidth="150.0" />


    <Button fx:id="flagButton" layoutX="30.0" layoutY="416.0" prefWidth="70.0" text="Flag" />
   <Button layoutX="565.0" layoutY="430.0" mnemonicParsing="false" onAction="#BackButton" text="Back" />

</AnchorPane>
