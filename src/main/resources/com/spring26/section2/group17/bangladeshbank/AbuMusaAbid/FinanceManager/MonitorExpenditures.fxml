<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.spring26.section2.group17.bangladeshbank.AbuMusaAbid.FinanceManager.MonitorExpendituresController"
            prefHeight="450.0" prefWidth="650.0">

    <!-- Title -->
    <Label layoutX="220.0" layoutY="10.0" text="Monitor Expenditures"
           style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

    <!-- Expenditure Table -->
    <TableView fx:id="expenditureTable" layoutX="30.0" layoutY="50.0"
               prefWidth="590.0" prefHeight="200.0">
        <columns>
            <TableColumn fx:id="transactionIdColumn" text="Transaction ID" prefWidth="110.0"/>
            <TableColumn fx:id="departmentColumn" text="Department" prefWidth="120.0"/>
            <TableColumn fx:id="amountColumn" text="Amount" prefWidth="100.0"/>
            <TableColumn fx:id="dateColumn" text="Date" prefWidth="110.0"/>
            <TableColumn fx:id="recordedByColumn" text="Recorded By" prefWidth="150.0"/>
        </columns>
    </TableView>

    <!-- Details Section -->
    <Label layoutX="30.0" layoutY="270.0" text="Transaction Details:"/>

    <TextArea fx:id="detailsArea" layoutX="30.0" layoutY="290.0"
              prefWidth="590.0" prefHeight="80.0" editable="false"/>

    <!-- Additional Info -->
    <Label layoutX="30.0" layoutY="380.0" text="Payment Method:"/>
    <TextField fx:id="paymentMethodField" layoutX="140.0" layoutY="375.0" prefWidth="150.0" editable="false"/>

    <Label layoutX="310.0" layoutY="380.0" text="Linked Budget:"/>
    <TextField fx:id="budgetField" layoutX="420.0" layoutY="375.0" prefWidth="150.0" editable="false"/>

    <!-- Flag Button -->
    <Button fx:id="flagButton" layoutX="550.0" layoutY="410.0"
            text="Flag" prefWidth="70.0"/>

</AnchorPane>