<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Line?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="580.0" prefWidth="793.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.spring26.section2.group17.bangladeshbank.MahmudulHasan.PaymentSystemsOfficer.MonitorFraudRiskController">
    <children>

        <!-- Top Header -->
        <Label layoutX="231.0" layoutY="15.0" style="-fx-font-size: 20px; -fx-font-weight: bold;" text="Transaction Settlement Monitoring System" />

        <Button fx:id="accessBtn" layoutX="616.0" layoutY="52.0" prefWidth="150.0" text="Access Module" />

        <!-- Left Input Panel -->
        <VBox layoutX="18.0" layoutY="90.0" prefWidth="250.0" spacing="10.0" style="-fx-border-color: gray; -fx-padding: 10;">
            <children>
                <Label style="-fx-font-weight: bold;" text="Transaction Input" />

                <TextField fx:id="txnIdField" promptText="Transaction ID" />
                <TextField fx:id="accountField" promptText="Account نمبر" />
                <TextField fx:id="amountField" promptText="Amount" />
                <TextField fx:id="dateField" promptText="Date / Filter" />

                <Button fx:id="inputBtn" text="Enter Data" />
            </children>
        </VBox>

        <!-- Center Workflow Controls -->
        <VBox layoutX="283.0" layoutY="88.0" prefHeight="222.0" prefWidth="252.0" spacing="15.0" style="-fx-border-color: #cccccc; -fx-padding: 15;">
            <children>
                <Label style="-fx-font-weight: bold;" text="Settlement Workflow" />

                <Button fx:id="validateBtn" prefWidth="200.0" text="Validate Input (VL)" />
                <Button fx:id="verifyBtn" prefWidth="200.0" text="Verify Transaction (VR)" />
                <Button fx:id="processBtn" prefWidth="200.0" text="Process Settlement (DP)" />
                <Button fx:id="outputBtn" prefWidth="200.0" text="Generate Output (OP)" />
            </children>
        </VBox>

        <!-- Right Status Panel -->
        <VBox layoutX="552.0" layoutY="88.0" prefHeight="221.0" prefWidth="224.0" spacing="10.0" style="-fx-border-color: #999999; -fx-padding: 10;">
            <children>
                <Label style="-fx-font-weight: bold;" text="Live Status" />

                <Label fx:id="statusAccess" text="Access: Pending" />
                <Label fx:id="statusInput" text="Input: Pending" />
                <Label fx:id="statusValidate" text="Validation: Pending" />
                <Label fx:id="statusVerify" text="Verification: Pending" />
                <Label fx:id="statusProcess" text="Processing: Pending" />
                <Label fx:id="statusOutput" text="Output: Pending" />
            </children>
        </VBox>

        <!-- Bottom Table -->
        <TableView fx:id="settlementTable" layoutX="15.0" layoutY="319.0" prefHeight="254.0" prefWidth="765.0">

            <columns>
                <TableColumn fx:id="txnCol" prefWidth="100.0" text="Txn ID" />
                <TableColumn fx:id="accountCol" prefWidth="120.0" text="Account" />
                <TableColumn fx:id="amountCol" prefWidth="100.0" text="Amount" />
                <TableColumn fx:id="dateCol" prefWidth="120.0" text="Date" />
                <TableColumn fx:id="statusCol" prefWidth="120.0" text="Status" />
                <TableColumn fx:id="resultCol" prefWidth="250.0" text="Result" />
            </columns>

        </TableView>
        <Line endX="397.00006103515625" layoutX="396.0" layoutY="43.0" startX="-399.7166442871094" />
      <Button layoutX="708.0" layoutY="12.0" mnemonicParsing="false" onAction="#backButton" style="-fx-background-color: red; -fx-text-fill: white;" text="Back">
         <font>
            <Font name="System Bold" size="13.0" />
         </font></Button>

    </children>

</AnchorPane>
