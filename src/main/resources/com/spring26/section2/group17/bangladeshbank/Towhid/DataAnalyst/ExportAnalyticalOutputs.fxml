<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="500.0" prefWidth="800.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.spring26.section2.group17.bangladeshbank.Towhid.DataAnalyst.ExportAnalyticalOutputsController">

    <!-- Define ToggleGroup ONLY ONCE -->
    <fx:define>
        <ToggleGroup fx:id="formatGroup" />
    </fx:define>

    <children>

        <Label layoutX="250.0" layoutY="20.0" style="-fx-font-size:18px; -fx-font-weight:bold;" text="Export Analytical Outputs" />

        <Label layoutX="50.0" layoutY="90.0" text="Select Result:" />
        <ComboBox fx:id="resultComboBox" layoutX="200.0" layoutY="85.0" prefWidth="250.0" />

        <Label layoutX="50.0" layoutY="150.0" text="Select Export Format:" />

        <!-- FIXED: Use SAME ToggleGroup -->
        <RadioButton fx:id="csvRadio" layoutX="220.0" layoutY="150.0" text="CSV" toggleGroup="$formatGroup" />

        <RadioButton fx:id="pdfRadio" layoutX="300.0" layoutY="150.0" text="PDF" toggleGroup="$formatGroup" />

        <Button layoutX="250.0" layoutY="210.0" onAction="#ExportbuttonOA" prefWidth="120.0" text="Export" />

        <Label layoutX="50.0" layoutY="270.0" style="-fx-font-size:14px; -fx-font-weight:bold;" text="Export Status:" />

        <TextArea fx:id="statusArea" editable="false" layoutX="50.0" layoutY="300.0" prefHeight="150.0" prefWidth="700.0" />

        <Button layoutX="682.0" layoutY="47.0" onAction="#ButtonOA" text="BackButton" />

    </children>
</AnchorPane>
