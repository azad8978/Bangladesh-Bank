<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="540.0" prefWidth="703.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.spring26.section2.group17.bangladeshbank.MahmudulHasan.PaymentSystemsOfficer.ManageElectronicFundTransfersController">

    <children>

        <!-- Header -->
        <Label layoutX="209.0" layoutY="14.0" style="-fx-font-size: 20px; -fx-font-weight: bold;" text="Manage Electronic Fund Transfers" />

        <Label layoutX="49.0" layoutY="52.0" style="-fx-text-fill: gray;" text="Ensure accurate and timely electronic transactions" />

        <!-- Input Section -->
        <VBox layoutX="49.0" layoutY="82.0" prefHeight="98.0" prefWidth="252.0" spacing="10.0">
            <children>
                <TextField fx:id="accountField" prefWidth="250.0" promptText="Account Number" />
                <TextField fx:id="amountField" prefWidth="250.0" promptText="Amount" />
                <TextField fx:id="referenceField" prefWidth="250.0" promptText="Reference / Filter" />
            </children>
        </VBox>

        <!-- Workflow Buttons (6 Events) -->
        <HBox layoutX="49.0" layoutY="189.0" spacing="10.0">
            <children>
                <Button fx:id="accessBtn" text="1. Access" />
                <Button fx:id="inputBtn" text="2. Enter Data" />
                <Button fx:id="validateBtn" text="3. Validate" />
                <Button fx:id="verifyBtn" text="4. Verify" />
                <Button fx:id="processBtn" text="5. Process" />
                <Button fx:id="outputBtn" text="6. Output" />
            </children>
        </HBox>

        <!-- Table Output -->
        <TableView fx:id="transactionTable" layoutX="9.0" layoutY="240.0" prefHeight="289.0" prefWidth="684.0">

            <columns>
                <TableColumn fx:id="accountCol" prefWidth="128.0" text="Account" />
                <TableColumn fx:id="amountCol" prefWidth="129.0" text="Amount" />
                <TableColumn fx:id="referenceCol" prefWidth="144.0" text="Reference" />
                <TableColumn fx:id="statusCol" prefWidth="144.0" text="Status" />
                <TableColumn fx:id="resultCol" prefWidth="157.0" text="Result" />
            </columns>

        </TableView>

    </children>

</AnchorPane>
