<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.RadioButton?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="466.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.spring26.section2.group17.bangladeshbank.AbuMusaAbid.SystemUser.SubmitOperationalRequestsController">

    <Label layoutX="180.0" layoutY="10.0" style="-fx-font-size: 18px; -fx-font-weight: bold;" text="Submit Operational Requests" />

    <Label layoutX="50.0" layoutY="50.0" text="User Name:" />
    <TextField fx:id="userNameField" layoutX="150.0" layoutY="45.0" prefWidth="200.0" />

    <Label layoutX="50.0" layoutY="90.0" text="Request Priority:" />
    <RadioButton fx:id="mediumPriority" layoutX="150.0" layoutY="85.0" text="Medium Priority" />
    <RadioButton fx:id="highPriority" layoutX="280.0" layoutY="85.0" text="High Priority" />

    <Label layoutX="50.0" layoutY="130.0" text="Description:" />
    <TextArea fx:id="descriptionArea" layoutX="150.0" layoutY="125.0" prefHeight="100.0" prefWidth="350.0" />

    <Button fx:id="submitButton" layoutX="150.0" layoutY="240.0" prefWidth="120.0" text="Submit Request" />

    <TableView fx:id="requestTable" layoutX="50.0" layoutY="280.0" prefHeight="100.0" prefWidth="500.0">
        <columns>
            <TableColumn fx:id="userColumn" prefWidth="120.0" text="User Name" />
            <TableColumn fx:id="priorityColumn" prefWidth="100.0" text="Priority" />
            <TableColumn fx:id="descriptionColumn" prefWidth="280.0" text="Description" />
        </columns>
    </TableView>
   <Button layoutX="263.0" layoutY="408.0" mnemonicParsing="false" onAction="#BackButton" prefHeight="26.0" prefWidth="66.0" text="Back" />

</AnchorPane>
