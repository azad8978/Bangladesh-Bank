<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.spring26.section2.group17.bangladeshbank.AbuMusaAbid.SystemUser.SubmitOperationalRequestsController"
            prefHeight="400.0" prefWidth="600.0">

    <!-- Title -->
    <Label layoutX="180.0" layoutY="10.0" text="Submit Operational Requests" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

    <!-- User Name -->
    <Label layoutX="50.0" layoutY="50.0" text="User Name:"/>
    <TextField fx:id="userNameField" layoutX="150.0" layoutY="45.0" prefWidth="200.0"/>

    <!-- Request Priority -->
    <Label layoutX="50.0" layoutY="90.0" text="Request Priority:"/>
    <RadioButton fx:id="mediumPriority" layoutX="150.0" layoutY="85.0" text="Medium Priority"/>
    <RadioButton fx:id="highPriority" layoutX="280.0" layoutY="85.0" text="High Priority"/>

    <!-- Description -->
    <Label layoutX="50.0" layoutY="130.0" text="Description:"/>
    <TextArea fx:id="descriptionArea" layoutX="150.0" layoutY="125.0" prefWidth="350.0" prefHeight="100.0"/>

    <!-- Submit Button -->
    <Button fx:id="submitButton" layoutX="150.0" layoutY="240.0" text="Submit Request" prefWidth="120.0"/>

    <!-- Table to display submitted requests -->
    <TableView fx:id="requestTable" layoutX="50.0" layoutY="280.0" prefWidth="500.0" prefHeight="100.0">
        <columns>
            <TableColumn fx:id="userColumn" text="User Name" prefWidth="120.0"/>
            <TableColumn fx:id="priorityColumn" text="Priority" prefWidth="100.0"/>
            <TableColumn fx:id="descriptionColumn" text="Description" prefWidth="280.0"/>
        </columns>
    </TableView>

</AnchorPane>