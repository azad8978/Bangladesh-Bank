<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.spring26.section2.group17.bangladeshbank.MahmudulHasan.ForeignExchangeControlOfficer.FXPolicyImplementationController">
    <children>

        <!-- HEADER -->
        <HBox layoutX="0" layoutY="0" prefHeight="50" prefWidth="600" style="-fx-background-color: #2C3E50;">
            <children>
                <Label layoutX="20" prefHeight="23.0" prefWidth="595.0" style="-fx-font-size: 18px; -fx-font-weight: bold;" text="                                                      FX Policy Control System " textFill="WHITE" />
                <Button fx:id="btnPublish" layoutX="450" prefHeight="26.0" prefWidth="242.0" style="-fx-background-color: #27AE60; -fx-text-fill: white;" text="Publish Policy" />
            </children>
        </HBox>

        <!-- LEFT PANEL (ACTIONS) -->
        <VBox layoutX="0" layoutY="50" prefHeight="500" prefWidth="150" spacing="15" style="-fx-background-color: #ECF0F1; -fx-padding: 10;">

            <children>
                <Label style="-fx-font-weight: bold;" text="Policy Actions" />

                <!-- Event 1 -->
                <Button fx:id="btnOpenPanel" text="Open Policy Panel" />

                <!-- Event 5 -->
                <Button fx:id="btnArchive" text="Archive Policy" />
            </children>
        </VBox>

        <!-- CENTER: POLICY EDITOR -->
        <VBox layoutX="160" layoutY="60" prefHeight="300" prefWidth="260" spacing="10" style="-fx-border-color: #BDC3C7; -fx-padding: 10;">

            <children>
                <Label style="-fx-font-weight: bold;" text="Policy Editor" />

                <!-- Event 2 -->
                <TextField fx:id="policyIdField" promptText="Policy ID" />
                <TextField fx:id="policyTitleField" promptText="Policy Title" />

                <TextArea fx:id="policyTextArea" prefHeight="180" promptText="Write policy rules and directives here..." />
            </children>
        </VBox>

        <!-- RIGHT PANEL: VALIDATION + OUTPUT -->
        <VBox layoutX="430" layoutY="60" prefHeight="300" prefWidth="150" spacing="15" style="-fx-border-color: #BDC3C7; -fx-padding: 10;">

            <children>

                <!-- Event 3 -->
                <Label style="-fx-font-weight: bold;" text="Validation" />
                <Button fx:id="btnValidate" text="Validate Policy" />

                <Label text="Validation Result:" />
                <Label fx:id="validationLabel" text="Not Checked" />

                <!-- Event 4 -->
                <Label text="Publish Status:" />
                <Label fx:id="publishStatusLabel" text="Not Published" />

            </children>
        </VBox>

        <!-- BOTTOM: POLICY TABLE -->
        <TableView fx:id="policyTable" layoutX="160" layoutY="380" prefHeight="150" prefWidth="420">

            <columns>
                <TableColumn fx:id="colId" text="Policy ID" />
                <TableColumn fx:id="colTitle" text="Title" />
                <TableColumn fx:id="colStatus" text="Status" />
            </columns>

        </TableView>

    </children>

</AnchorPane>
