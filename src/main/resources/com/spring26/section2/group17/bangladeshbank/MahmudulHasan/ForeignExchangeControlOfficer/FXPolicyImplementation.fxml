<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.spring26.section2.group17.bangladeshbank.MahmudulHasan.ForeignExchangeControlOfficer.FXPolicyImplementationController"
            prefHeight="400.0" prefWidth="600.0">
    <children>

        <!-- HEADER -->
        <HBox layoutX="0" layoutY="0" prefWidth="600" prefHeight="50"
              style="-fx-background-color: #2C3E50;">
            <children>
                <Label text="FX Policy Control System"
                       textFill="WHITE"
                       style="-fx-font-size: 18px; -fx-font-weight: bold;"
                       layoutX="20"/>
                <Button text="Publish Policy"
                        fx:id="btnPublish"
                        layoutX="450"
                        style="-fx-background-color: #27AE60; -fx-text-fill: white;"/>
            </children>
        </HBox>

        <!-- LEFT PANEL (ACTIONS) -->
        <VBox layoutX="0" layoutY="50" prefWidth="150" prefHeight="500"
              spacing="15"
              style="-fx-background-color: #ECF0F1; -fx-padding: 10;">

            <children>
                <Label text="Policy Actions" style="-fx-font-weight: bold;"/>

                <!-- Event 1 -->
                <Button text="Open Policy Panel" fx:id="btnOpenPanel"/>

                <!-- Event 5 -->
                <Button text="Archive Policy" fx:id="btnArchive"/>
            </children>
        </VBox>

        <!-- CENTER: POLICY EDITOR -->
        <VBox layoutX="160" layoutY="60" prefWidth="260" prefHeight="300"
              spacing="10"
              style="-fx-border-color: #BDC3C7; -fx-padding: 10;">

            <children>
                <Label text="Policy Editor" style="-fx-font-weight: bold;"/>

                <!-- Event 2 -->
                <TextField fx:id="policyIdField" promptText="Policy ID"/>
                <TextField fx:id="policyTitleField" promptText="Policy Title"/>

                <TextArea fx:id="policyTextArea"
                          prefHeight="180"
                          promptText="Write policy rules and directives here..."/>
            </children>
        </VBox>

        <!-- RIGHT PANEL: VALIDATION + OUTPUT -->
        <VBox layoutX="430" layoutY="60" prefWidth="150" prefHeight="300"
              spacing="15"
              style="-fx-border-color: #BDC3C7; -fx-padding: 10;">

            <children>

                <!-- Event 3 -->
                <Label text="Validation" style="-fx-font-weight: bold;"/>
                <Button text="Validate Policy" fx:id="btnValidate"/>

                <Label text="Validation Result:"/>
                <Label fx:id="validationLabel" text="Not Checked"/>

                <!-- Event 4 -->
                <Label text="Publish Status:"/>
                <Label fx:id="publishStatusLabel" text="Not Published"/>

            </children>
        </VBox>

        <!-- BOTTOM: POLICY TABLE -->
        <TableView layoutX="160" layoutY="380" prefWidth="420" prefHeight="150"
                   fx:id="policyTable">

            <columns>
                <TableColumn text="Policy ID" fx:id="colId"/>
                <TableColumn text="Title" fx:id="colTitle"/>
                <TableColumn text="Status" fx:id="colStatus"/>
            </columns>

        </TableView>

        <!-- STATUS BAR -->
        <Label layoutX="20" layoutY="540"
               fx:id="statusBar"
               text="System Ready"
               style="-fx-text-fill: green;" />

    </children>

</AnchorPane>
