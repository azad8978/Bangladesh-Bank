<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.spring26.section2.group17.bangladeshbank.AbuMusaAbid.FinanceManager.GenerateFinancialReportsController"
            prefHeight="450.0" prefWidth="650.0">

    <!-- Title -->
    <Label layoutX="180.0" layoutY="10.0"
           text="Financial Reports"
           style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

    <!-- Report Type -->
    <Label layoutX="50.0" layoutY="70.0" text="Report Type:"/>
    <ComboBox fx:id="reportTypeComboBox"
              layoutX="180.0" layoutY="65.0"
              prefWidth="200.0"/>

    <!-- Date Range -->
    <Label layoutX="50.0" layoutY="110.0" text="From Date:"/>
    <TextField fx:id="fromDateField"
               layoutX="180.0" layoutY="105.0"
               prefWidth="120.0"/>

    <Label layoutX="320.0" layoutY="110.0" text="To Date:"/>
    <TextField fx:id="toDateField"
               layoutX="390.0" layoutY="105.0"
               prefWidth="120.0"/>

    <!-- Generate Button -->
    <Button fx:id="generateButton"
            layoutX="180.0" layoutY="150.0"
            text="Generate Report"
            prefWidth="150.0"/>

    <!-- Report Output -->
    <Label layoutX="50.0" layoutY="210.0" text="Total Revenue:"/>
    <Label fx:id="revenueLabel"
           layoutX="200.0" layoutY="210.0"
           text="0.00"/>

    <Label layoutX="50.0" layoutY="240.0" text="Total Expenses:"/>
    <Label fx:id="expenseLabel"
           layoutX="200.0" layoutY="240.0"
           text="0.00"/>

    <Label layoutX="50.0" layoutY="270.0" text="Net Balance:"/>
    <Label fx:id="balanceLabel"
           layoutX="200.0" layoutY="270.0"
           text="0.00"
           style="-fx-font-weight: bold;"/>

    <!-- Status Message -->
    <Label fx:id="statusLabel"
           layoutX="50.0" layoutY="320.0"
           text=""
           style="-fx-text-fill: green;"/>

</AnchorPane>