<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.spring26.section2.group17.bangladeshbank.MahmudulHasan.ForeignExchangeControlOfficer.AntiMoneyLaunderingAMLEnforcementController"
            prefHeight="400.0" prefWidth="600.0">
    <children>

        <!-- TOP HEADER BAR -->
        <HBox layoutX="0" layoutY="0" prefWidth="600" prefHeight="50"
              style="-fx-background-color: #1C2833;">
            <children>
                <Label text="AML Enforcement Dashboard"
                       textFill="WHITE"
                       style="-fx-font-size: 18px; -fx-font-weight: bold;"
                       layoutX="20"/>
            </children>
        </HBox>

        <!-- LEFT WORKFLOW TRACKER -->
        <VBox layoutX="0" layoutY="50" prefWidth="150" prefHeight="550"
              spacing="15"
              style="-fx-background-color: #EBF5FB; -fx-padding: 15;">

            <children>
                <Label text="Workflow" style="-fx-font-weight: bold;"/>

                <Label text="1. Access System"/>
                <Label text="2. Input Data"/>
                <Label text="3. Risk Analysis"/>
                <Label text="4. Alert"/>
                <Label text="5. Case Log"/>
            </children>
        </VBox>

        <!-- CARD 1: ACCESS SYSTEM -->
        <VBox layoutX="170" layoutY="70" prefWidth="400" prefHeight="70"
              spacing="10"
              style="-fx-background-color: white; -fx-padding: 10; -fx-border-color: #D5D8DC;">

            <children>
                <Label text="Access AML Monitoring System" style="-fx-font-weight: bold;"/>
                <Button text="Start Surveillance" fx:id="btnStart"/>
            </children>
        </VBox>

        <!-- CARD 2: INPUT DATA -->
        <VBox layoutX="170" layoutY="150" prefWidth="400" prefHeight="160"
              spacing="10"
              style="-fx-background-color: white; -fx-padding: 10; -fx-border-color: #D5D8DC;">

            <children>
                <Label text="Suspicious Transaction Input" style="-fx-font-weight: bold;"/>

                <TextField fx:id="accountField" promptText="Account Number"/>
                <TextField fx:id="transactionField" promptText="Transaction ID"/>
                <TextField fx:id="amountField" promptText="Amount"/>
                <TextField fx:id="countryField" promptText="Country"/>

                <Button text="Submit" fx:id="btnSubmit"/>
            </children>
        </VBox>

        <!-- CARD 3: RISK ANALYSIS -->
        <VBox layoutX="170" layoutY="320" prefWidth="400" prefHeight="120"
              spacing="10"
              style="-fx-background-color: white; -fx-padding: 10; -fx-border-color: #D5D8DC;">

            <children>
                <Label text="Risk Analysis Engine" style="-fx-font-weight: bold;"/>

                <Button text="Run Analysis" fx:id="btnAnalyze"/>

                <Label fx:id="riskScoreLabel" text="Risk Score: --"/>
                <ProgressIndicator fx:id="riskIndicator" progress="0.0"/>
            </children>
        </VBox>

        <!-- CARD 4: ALERT -->
        <VBox layoutX="170" layoutY="450" prefWidth="400" prefHeight="100"
              spacing="10"
              style="-fx-background-color: #FDEDEC; -fx-padding: 10; -fx-border-color: #E74C3C;">

            <children>
                <Label text="Investigation Alert" style="-fx-font-weight: bold;"/>

                <Label fx:id="alertLabel"
                       text="No Alert"
                       style="-fx-font-size: 14px;"/>

            </children>
        </VBox>

        <!-- CARD 5: CASE LOG -->
        <VBox layoutX="170" layoutY="560" prefWidth="400" prefHeight="140"
              spacing="10"
              style="-fx-background-color: white; -fx-padding: 10; -fx-border-color: #D5D8DC;">

            <children>
                <Label text="Case Log Records" style="-fx-font-weight: bold;"/>

                <TableView fx:id="caseTable" prefHeight="100">
                    <columns>
                        <TableColumn text="Account" fx:id="colAccount"/>
                        <TableColumn text="Txn ID" fx:id="colTxn"/>
                        <TableColumn text="Amount" fx:id="colAmount"/>
                        <TableColumn text="Risk" fx:id="colRisk"/>
                    </columns>
                </TableView>

            </children>

        </VBox>

    </children>
</AnchorPane>
