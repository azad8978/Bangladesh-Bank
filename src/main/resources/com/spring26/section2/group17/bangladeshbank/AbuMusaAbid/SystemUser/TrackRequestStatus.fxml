<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.spring26.section2.group17.bangladeshbank.AbuMusaAbid.SystemUser.TrackRequestStatusController"
            prefHeight="400.0" prefWidth="600.0">

    <!-- Title -->
    <Label layoutX="200.0" layoutY="10.0" text="Track Request Status" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

    <!-- TableView for Requests -->
    <TableView fx:id="requestTable" layoutX="50.0" layoutY="50.0" prefWidth="500.0" prefHeight="200.0">
        <columns>
            <TableColumn fx:id="idColumn" text="Request ID" prefWidth="100.0"/>
            <TableColumn fx:id="typeColumn" text="Type" prefWidth="120.0"/>
            <TableColumn fx:id="dateColumn" text="Date" prefWidth="140.0"/>
            <TableColumn fx:id="statusColumn" text="Status" prefWidth="140.0"/>
        </columns>
    </TableView>

    <!-- Timeline Label -->
    <Label layoutX="50.0" layoutY="270.0" text="Request Timeline:"/>

    <!-- TextArea to show timeline -->
    <TextArea fx:id="timelineArea" layoutX="50.0" layoutY="290.0" prefWidth="500.0" prefHeight="90.0" editable="false"/>

</AnchorPane>