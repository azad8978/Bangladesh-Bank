<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="452.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.spring26.section2.group17.bangladeshbank.AbuMusaAbid.SystemUser.TrackRequestStatusController">

    <Label layoutX="200.0" layoutY="10.0" style="-fx-font-size: 18px; -fx-font-weight: bold;" text="Track Request Status" />

    <TableView fx:id="requestTable" layoutX="50.0" layoutY="50.0" prefHeight="200.0" prefWidth="500.0">
        <columns>
            <TableColumn fx:id="idColumn" prefWidth="100.0" text="Request ID" />
            <TableColumn fx:id="typeColumn" prefWidth="120.0" text="Type" />
            <TableColumn fx:id="dateColumn" prefWidth="140.0" text="Date" />
            <TableColumn fx:id="statusColumn" prefWidth="140.0" text="Status" />
        </columns>
    </TableView>

    <Label layoutX="50.0" layoutY="270.0" text="Request Timeline:" />

    <TextArea fx:id="timelineArea" editable="false" layoutX="50.0" layoutY="290.0" prefHeight="90.0" prefWidth="500.0" />
   <Button layoutX="253.0" layoutY="399.0" mnemonicParsing="false" onAction="#BackButton" text="Back" />

</AnchorPane>
