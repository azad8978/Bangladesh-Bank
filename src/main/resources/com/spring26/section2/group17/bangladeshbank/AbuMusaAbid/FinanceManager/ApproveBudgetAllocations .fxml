<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.spring26.section2.group17.bangladeshbank.AbuMusaAbid.FinanceManager.ApproveBudgetAllocationsController"
            prefHeight="450.0" prefWidth="650.0">

    <!-- Title -->
    <Label layoutX="200.0" layoutY="10.0" text="Approve Budget Allocations"
           style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

    <!-- Budget Request Table -->
    <TableView fx:id="budgetTable" layoutX="30.0" layoutY="50.0" prefWidth="590.0" prefHeight="200.0">
        <columns>
            <TableColumn fx:id="departmentColumn" text="Department" prefWidth="140.0"/>
            <TableColumn fx:id="amountColumn" text="Requested Amount" prefWidth="130.0"/>
            <TableColumn fx:id="requestedByColumn" text="Requested By" prefWidth="130.0"/>
            <TableColumn fx:id="purposeColumn" text="Purpose" prefWidth="190.0"/>
        </columns>
    </TableView>

    <!-- Selected Request Details -->
    <Label layoutX="30.0" layoutY="270.0" text="Selected Request Details:"/>

    <TextArea fx:id="detailsArea" layoutX="30.0" layoutY="290.0"
              prefWidth="590.0" prefHeight="70.0" editable="false"/>

    <!-- Comment / Reason -->
    <Label layoutX="30.0" layoutY="370.0" text="Comment / Reason:"/>
    <TextField fx:id="commentField" layoutX="160.0" layoutY="365.0" prefWidth="300.0"/>

    <!-- Buttons -->
    <Button fx:id="approveButton" layoutX="480.0" layoutY="360.0"
            text="Approve" prefWidth="70.0"/>

    <Button fx:id="rejectButton" layoutX="560.0" layoutY="360.0"
            text="Reject" prefWidth="70.0"/>

</AnchorPane>