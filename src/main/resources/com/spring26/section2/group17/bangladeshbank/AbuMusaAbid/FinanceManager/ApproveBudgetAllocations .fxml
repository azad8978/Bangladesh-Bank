<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="450.0" prefWidth="650.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.spring26.section2.group17.bangladeshbank.AbuMusaAbid.FinanceManager.ApproveBudgetAllocationsController">

    <Label layoutX="200.0" layoutY="10.0" style="-fx-font-size: 18px; -fx-font-weight: bold;" text="Approve Budget Allocations" />

    <TableView fx:id="budgetTable" layoutX="30.0" layoutY="50.0" prefHeight="200.0" prefWidth="590.0">
        <columns>
            <TableColumn fx:id="departmentColumn" prefWidth="140.0" text="Department" />
            <TableColumn fx:id="amountColumn" prefWidth="130.0" text="Requested Amount" />
            <TableColumn fx:id="requestedByColumn" prefWidth="130.0" text="Requested By" />
            <TableColumn fx:id="purposeColumn" prefWidth="190.0" text="Purpose" />
        </columns>
    </TableView>

    <Label layoutX="30.0" layoutY="270.0" text="Selected Request Details:" />

    <TextArea fx:id="detailsArea" editable="false" layoutX="30.0" layoutY="290.0" prefHeight="70.0" prefWidth="590.0" />

    <Label layoutX="30.0" layoutY="370.0" text="Comment / Reason:" />
    <TextField fx:id="commentField" layoutX="160.0" layoutY="365.0" prefWidth="300.0" />

    <Button fx:id="approveButton" layoutX="480.0" layoutY="360.0" prefWidth="70.0" text="Approve" />

    <Button fx:id="rejectButton" layoutX="560.0" layoutY="360.0" prefWidth="70.0" text="Reject" />
   <Button layoutX="575.0" layoutY="403.0" mnemonicParsing="false" onAction="#BackButton" text="Back" />

</AnchorPane>
