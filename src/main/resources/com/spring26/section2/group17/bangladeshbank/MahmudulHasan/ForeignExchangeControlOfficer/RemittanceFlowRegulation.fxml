<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.spring26.section2.group17.bangladeshbank.MahmudulHasan.ForeignExchangeControlOfficer.RemittanceFlowRegulationController">

    <children>

        <!-- HEADER -->
        <HBox layoutX="0" layoutY="0" prefHeight="50" prefWidth="600" style="-fx-background-color: #154360;">
            <children>
                <Label layoutX="20" prefHeight="23.0" prefWidth="503.0" style="-fx-font-size: 18px; -fx-font-weight: bold;" text="                                          Remittance Flow Regulation System" textFill="WHITE" />
                <!-- Event 1 -->
                <Button fx:id="btnOpenPortal" layoutX="450" prefHeight="26.0" prefWidth="90.0" text="Open Portal" />
            </children>
        </HBox>

        <!-- FLOW SECTION -->
        <HBox layoutX="20" layoutY="70" spacing="15">

            <!-- EVENT 2: INPUT DATA -->
            <VBox prefWidth="170" spacing="8" style="-fx-border-color: #AAB7B8; -fx-padding: 10;">
                <children>
                    <Label style="-fx-font-weight: bold;" text="Remittance Input" />

                    <TextField fx:id="senderField" promptText="Sender Name" />
                    <TextField fx:id="receiverField" promptText="Receiver Name" />
                    <TextField fx:id="amountField" promptText="Amount" />

                    <Button fx:id="btnSubmit" text="Submit" />
                </children>
            </VBox>

            <!-- EVENT 3: VERIFICATION -->
            <VBox prefWidth="170" spacing="10" style="-fx-border-color: #AAB7B8; -fx-padding: 10;">
                <children>
                    <Label style="-fx-font-weight: bold;" text="Source Verification" />

                    <Button fx:id="btnVerify" text="Verify Source" />

                    <CheckBox fx:id="sourceCheck" text="Legitimate Source" />

                    <Label text="Verification Result:" />
                    <Label fx:id="verifyLabel" text="Pending" />
                </children>
            </VBox>

            <!-- EVENT 4: RESULT -->
            <VBox prefHeight="175.0" prefWidth="189.0" spacing="10" style="-fx-border-color: #AAB7B8; -fx-padding: 10;">
                <children>
                    <Label style="-fx-font-weight: bold;" text="Confirmation Status" />

                    <Label fx:id="statusLabel" style="-fx-font-size: 14px;" text="Not Processed" />

                    <ProgressBar fx:id="statusBarProgress" progress="0.0" />
                </children>
            </VBox>

        </HBox>

        <!-- EVENT 5: TRANSACTION LOG -->
        <TableView fx:id="remittanceTable" layoutX="20" layoutY="250" prefHeight="200" prefWidth="560">

            <columns>
                <TableColumn fx:id="colSender" text="Sender" />
                <TableColumn fx:id="colReceiver" text="Receiver" />
                <TableColumn fx:id="colAmount" text="Amount" />
                <TableColumn fx:id="colStatus" text="Status" />
            </columns>

        </TableView>

    </children>

</AnchorPane>
