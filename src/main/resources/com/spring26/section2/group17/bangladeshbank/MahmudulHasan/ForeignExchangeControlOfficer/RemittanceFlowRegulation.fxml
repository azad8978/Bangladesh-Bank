<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.spring26.section2.group17.bangladeshbank.MahmudulHasan.ForeignExchangeControlOfficer.RemittanceFlowRegulationController"
            prefHeight="400.0" prefWidth="600.0">

    <children>

        <!-- HEADER -->
        <HBox layoutX="0" layoutY="0" prefWidth="600" prefHeight="50"
              style="-fx-background-color: #154360;">
            <children>
                <Label text="Remittance Flow Regulation System"
                       textFill="WHITE"
                       style="-fx-font-size: 18px; -fx-font-weight: bold;"
                       layoutX="20"/>
                <!-- Event 1 -->
                <Button text="Open Portal"
                        fx:id="btnOpenPortal"
                        layoutX="450"/>
            </children>
        </HBox>

        <!-- FLOW SECTION -->
        <HBox layoutX="20" layoutY="70" spacing="15">

            <!-- EVENT 2: INPUT DATA -->
            <VBox prefWidth="170" spacing="8"
                  style="-fx-border-color: #AAB7B8; -fx-padding: 10;">
                <children>
                    <Label text="Remittance Input"
                           style="-fx-font-weight: bold;"/>

                    <TextField fx:id="senderField" promptText="Sender Name"/>
                    <TextField fx:id="receiverField" promptText="Receiver Name"/>
                    <TextField fx:id="amountField" promptText="Amount"/>

                    <Button text="Submit"
                            fx:id="btnSubmit"/>
                </children>
            </VBox>

            <!-- EVENT 3: VERIFICATION -->
            <VBox prefWidth="170" spacing="10"
                  style="-fx-border-color: #AAB7B8; -fx-padding: 10;">
                <children>
                    <Label text="Source Verification"
                           style="-fx-font-weight: bold;"/>

                    <Button text="Verify Source"
                            fx:id="btnVerify"/>

                    <CheckBox fx:id="sourceCheck"
                              text="Legitimate Source"/>

                    <Label text="Verification Result:"/>
                    <Label fx:id="verifyLabel" text="Pending"/>
                </children>
            </VBox>

            <!-- EVENT 4: RESULT -->
            <VBox prefWidth="170" spacing="10"
                  style="-fx-border-color: #AAB7B8; -fx-padding: 10;">
                <children>
                    <Label text="Confirmation Status"
                           style="-fx-font-weight: bold;"/>

                    <Label fx:id="statusLabel"
                           text="Not Processed"
                           style="-fx-font-size: 14px;"/>

                    <ProgressBar fx:id="statusBarProgress"
                                 progress="0.0"/>
                </children>
            </VBox>

        </HBox>

        <!-- EVENT 5: TRANSACTION LOG -->
        <TableView layoutX="20" layoutY="250"
                   prefWidth="560" prefHeight="200"
                   fx:id="remittanceTable">

            <columns>
                <TableColumn text="Sender" fx:id="colSender"/>
                <TableColumn text="Receiver" fx:id="colReceiver"/>
                <TableColumn text="Amount" fx:id="colAmount"/>
                <TableColumn text="Status" fx:id="colStatus"/>
            </columns>

        </TableView>

        <!-- STATUS BAR -->
        <Label layoutX="20" layoutY="470"
               fx:id="systemStatus"
               text="System Ready"
               style="-fx-text-fill: green;" />

    </children>

</AnchorPane>
