<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="550.0" prefWidth="850.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.spring26.section2.group17.bangladeshbank.Towhid.CyberSecurityOfficer.InitiateIncidentResponseController">

    <children>

        <!-- Title -->
        <Label layoutX="280.0" layoutY="20.0" style="-fx-font-size:18px; -fx-font-weight:bold;" text="Initiate Incident Response" />

        <!-- Incident Type -->
        <Label layoutX="50.0" layoutY="90.0" text="Incident Type:" />
        <ComboBox fx:id="incidentTypeComboBox" layoutX="200.0" layoutY="85.0" prefWidth="250.0" />

        <!-- Severity Level -->
        <Label layoutX="50.0" layoutY="140.0" text="Severity Level:" />
        <ComboBox fx:id="severityComboBox" layoutX="200.0" layoutY="135.0" prefWidth="250.0" />

        <!-- Description -->
        <Label layoutX="50.0" layoutY="190.0" text="Description:" />
        <TextArea fx:id="descriptionArea" layoutX="200.0" layoutY="185.0" prefHeight="120.0" prefWidth="400.0" />

        <!-- Initiate Button -->
        <Button layoutX="300.0" layoutY="330.0" onAction="#initiateresponse" prefWidth="180.0" text="Initiate Response" />

        <!-- Status -->
        <Label layoutX="50.0" layoutY="390.0" style="-fx-font-weight:bold;" text="System Status:" />

        <TextArea fx:id="statusArea" editable="false" layoutX="50.0" layoutY="420.0" prefHeight="100.0" prefWidth="750.0" />
      <Button layoutX="548.0" layoutY="330.0" mnemonicParsing="false" onAction="#ButtonOA" text="BackButton" />

    </children>

</AnchorPane>
