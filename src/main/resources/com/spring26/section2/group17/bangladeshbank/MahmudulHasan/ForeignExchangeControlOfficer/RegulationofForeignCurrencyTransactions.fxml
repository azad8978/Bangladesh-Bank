<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.spring26.section2.group17.bangladeshbank.MahmudulHasan.ForeignExchangeControlOfficer.RegulationofForeignCurrencyTransactionsController"
            prefHeight="400.0" prefWidth="600.0">
    <children>
        <VBox spacing="15.0" layoutX="20.0" layoutY="20.0">

            <!-- Title -->
            <Label text="Foreign Currency Transaction Control"
                   style="-fx-font-size: 18px; -fx-font-weight: bold;" />

            <!-- Form -->
            <GridPane hgap="10" vgap="10">

                <Label text="Sender:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                <TextField fx:id="senderField" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                <Label text="Receiver:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                <TextField fx:id="receiverField" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                <Label text="Amount:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                <TextField fx:id="amountField" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                <Label text="Purpose:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                <TextField fx:id="purposeField" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

            </GridPane>

            <!-- Buttons -->
            <HBox spacing="10">

                <Button text="Validate" onAction="#handleValidate"/>
                <Button text="Approve" onAction="#handleApprove"/>
                <Button text="Reject" onAction="#handleReject"/>
                <Button text="Save Record" onAction="#handleSave"/>

            </HBox>

            <!-- Table -->
            <TableView fx:id="transactionTable" prefHeight="200">

                <columns>
                    <TableColumn text="Sender" fx:id="colSender"/>
                    <TableColumn text="Receiver" fx:id="colReceiver"/>
                    <TableColumn text="Amount" fx:id="colAmount"/>
                    <TableColumn text="Purpose" fx:id="colPurpose"/>
                    <TableColumn text="Status" fx:id="colStatus"/>
                </columns>

            </TableView>

            <!-- Status Output -->
            <Label fx:id="statusLabel"
                   text="Status will appear here..."
                   style="-fx-text-fill: blue;" />

        </VBox>
    </children>

</AnchorPane>
