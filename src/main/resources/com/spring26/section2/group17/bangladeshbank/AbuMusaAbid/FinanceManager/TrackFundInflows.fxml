<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.spring26.section2.group17.bangladeshbank.AbuMusaAbid.FinanceManager.TrackFundInflowsController"
            prefHeight="450.0" prefWidth="650.0">

    <!-- Title -->
    <Label layoutX="220.0" layoutY="10.0"
           text="Track Fund Inflows"
           style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

    <!-- Filters -->
    <Label layoutX="30.0" layoutY="50.0" text="Source:"/>
    <ComboBox fx:id="sourceComboBox" layoutX="100.0" layoutY="45.0" prefWidth="150.0"/>

    <Label layoutX="270.0" layoutY="50.0" text="From Date:"/>
    <TextField fx:id="fromDateField" layoutX="350.0" layoutY="45.0" prefWidth="100.0"/>

    <Label layoutX="470.0" layoutY="50.0" text="To Date:"/>
    <TextField fx:id="toDateField" layoutX="530.0" layoutY="45.0" prefWidth="100.0"/>

    <Button fx:id="filterButton" layoutX="530.0" layoutY="80.0"
            text="Filter" prefWidth="100.0"/>

    <!-- Fund Inflows Table -->
    <TableView fx:id="fundTable" layoutX="30.0" layoutY="120.0"
               prefWidth="600.0" prefHeight="250.0">
        <columns>
            <TableColumn fx:id="sourceColumn" text="Source" prefWidth="150.0"/>
            <TableColumn fx:id="amountColumn" text="Amount" prefWidth="120.0"/>
            <TableColumn fx:id="dateColumn" text="Date" prefWidth="150.0"/>
            <TableColumn fx:id="transactionIdColumn" text="Transaction ID" prefWidth="180.0"/>
        </columns>
    </TableView>

</AnchorPane>