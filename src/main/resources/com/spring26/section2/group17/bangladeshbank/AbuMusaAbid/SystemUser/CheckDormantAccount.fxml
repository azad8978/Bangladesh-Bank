<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="450.0" prefWidth="650.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.spring26.section2.group17.bangladeshbank.AbuMusaAbid.SystemUser.CheckDormantAccountController">

    <!-- Title -->
    <Label layoutX="200.0" layoutY="10.0" style="-fx-font-size: 18px; -fx-font-weight: bold;" text="Claim Your Money (Dormant Account)" />

    <!-- Name / NID -->
    <Label layoutX="50.0" layoutY="70.0" text="Name / NID:" />
    <TextField fx:id="nameNidField" layoutX="180.0" layoutY="65.0" prefWidth="250.0" />

    <!-- Bank Name (Optional) -->
    <Label layoutX="50.0" layoutY="110.0" text="Bank Name (Optional):" />
    <TextField fx:id="bankNameField" layoutX="180.0" layoutY="105.0" prefWidth="250.0" />

    <!-- Search Button -->
    <Button fx:id="searchButton" layoutX="180.0" layoutY="150.0" prefWidth="120.0" text="Search" />

    <!-- Result Table -->
    <TableView fx:id="resultTable" layoutX="50.0" layoutY="200.0" prefHeight="180.0" prefWidth="550.0">

        <columns>
            <TableColumn fx:id="accountNameColumn" prefWidth="150.0" text="Account Name" />
            <TableColumn fx:id="bankColumn" prefWidth="120.0" text="Bank" />
            <TableColumn fx:id="amountColumn" prefWidth="120.0" text="Amount" />
            <TableColumn fx:id="statusColumn" prefWidth="150.0" text="Status" />
        </columns>

    </TableView>

    <!-- Message Label -->
    <Label fx:id="messageLabel" layoutX="50.0" layoutY="390.0" style="-fx-text-fill: red;" text="" />
   <Button layoutX="278.0" layoutY="395.0" mnemonicParsing="false" onAction="#BackButton" text="Back" />

</AnchorPane>
