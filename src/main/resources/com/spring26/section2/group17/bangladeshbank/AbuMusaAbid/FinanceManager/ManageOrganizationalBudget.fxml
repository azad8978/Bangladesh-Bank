<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="510.0" prefWidth="700.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.spring26.section2.group17.bangladeshbank.AbuMusaAbid.FinanceManager.ManageOrganizationalBudgetController">
    <Label layoutX="200.0" layoutY="10.0" style="-fx-font-size: 18px; -fx-font-weight: bold;" text="Budget Management Dashboard" />

    <Label layoutX="50.0" layoutY="70.0" text="Budget Name:" />
    <TextField fx:id="budgetNameField" layoutX="200.0" layoutY="65.0" prefWidth="250.0" />

    <Label layoutX="50.0" layoutY="110.0" text="Fiscal Period:" />
    <TextField fx:id="fiscalPeriodField" layoutX="200.0" layoutY="105.0" prefWidth="250.0" promptText="e.g. 2025-2026" />

    <Label layoutX="50.0" layoutY="150.0" text="Total Amount:" />
    <TextField fx:id="amountField" layoutX="200.0" layoutY="145.0" prefWidth="250.0" />

    <Button fx:id="createButton" layoutX="200.0" layoutY="190.0" prefWidth="180.0" text="Create New Budget" />
    <TableView fx:id="budgetTable" layoutX="50.0" layoutY="240.0" prefHeight="170.0" prefWidth="600.0">

        <columns>
            <TableColumn fx:id="nameColumn" prefWidth="150.0" text="Budget Name" />
            <TableColumn fx:id="periodColumn" prefWidth="150.0" text="Fiscal Period" />
            <TableColumn fx:id="amountColumn" prefWidth="150.0" text="Total Amount" />
            <TableColumn fx:id="statusColumn" prefWidth="150.0" text="Status" />
        </columns>

    </TableView>

    <Label fx:id="messageLabel" layoutX="50.0" layoutY="420.0" style="-fx-text-fill: green;" text="" />
   <Button layoutX="559.0" layoutY="460.0" mnemonicParsing="false" onAction="#BackButton" text="Back" />

</AnchorPane>

