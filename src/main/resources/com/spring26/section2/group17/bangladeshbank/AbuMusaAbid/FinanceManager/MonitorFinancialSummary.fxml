<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.chart.PieChart?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="450.0" prefWidth="700.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.spring26.section2.group17.bangladeshbank.AbuMusaAbid.FinanceManager.MonitorFinancialSummaryController">

    <!-- Title -->
    <Label layoutX="220.0" layoutY="10.0" style="-fx-font-size: 18px; -fx-font-weight: bold;" text="Financial Overview Dashboard" />

    <!-- Time Period Selection -->
    <Label layoutX="50.0" layoutY="50.0" text="Time Period:" />
    <ComboBox fx:id="timePeriodCombo" layoutX="150.0" layoutY="45.0" prefWidth="150.0" />

    <Button fx:id="updateButton" layoutX="320.0" layoutY="45.0" prefWidth="80.0" text="Update" />

    <!-- Revenue BarChart -->
    <BarChart fx:id="revenueChart" layoutX="50.0" layoutY="90.0" prefHeight="200.0" prefWidth="300.0">
        <xAxis>
            <CategoryAxis label="Category" />
        </xAxis>
        <yAxis>
            <NumberAxis label="Revenue" />
        </yAxis>
    </BarChart>

    <!-- Expenditure PieChart -->
    <PieChart fx:id="expenditureChart" layoutX="380.0" layoutY="90.0" prefHeight="200.0" prefWidth="250.0" />

    <!-- Summary Metrics -->
    <Label layoutX="50.0" layoutY="310.0" text="Total Revenue:" />
    <Label fx:id="totalRevenueLabel" layoutX="180.0" layoutY="310.0" text="0" />

    <Label layoutX="50.0" layoutY="340.0" text="Total Expenditure:" />
    <Label fx:id="totalExpenditureLabel" layoutX="200.0" layoutY="340.0" text="0" />

    <Label layoutX="50.0" layoutY="370.0" text="Net Profit/Loss:" />
    <Label fx:id="netResultLabel" layoutX="190.0" layoutY="370.0" text="0" />
   <Button layoutX="569.0" layoutY="394.0" mnemonicParsing="false" onAction="#BackButton" text="Back" />

</AnchorPane>
