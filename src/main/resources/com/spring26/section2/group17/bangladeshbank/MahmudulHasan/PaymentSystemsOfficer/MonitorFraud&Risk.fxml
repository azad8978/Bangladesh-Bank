<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="465.0" prefWidth="730.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.spring26.section2.group17.bangladeshbank.MahmudulHasan.PaymentSystemsOfficer.MonitorFraudRiskController">
    <!-- Header -->
    <HBox spacing="10" style="-fx-background-color: #2E8B57; -fx-padding: 10;" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">
        <Label prefHeight="30.0" prefWidth="625.0" style="-fx-text-fill: white;" text="                                            ⚠ Banking Fraud Risk Monitoring System">
            <font>
                <Font size="20" />
            </font>
        </Label>
        <Pane HBox.hgrow="ALWAYS" />
        <Button text="Logout" />
    </HBox>

    <!-- Sidebar -->
    <VBox layoutY="51.2" prefHeight="437.0" prefWidth="150.0" spacing="15" style="-fx-background-color: #f0f0f0; -fx-padding: 10;" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.topAnchor="51.0">
        <Label style="-fx-font-weight: bold;" text="Navigation" />
        <Button maxWidth="Infinity" text="Dashboard" />
        <Button maxWidth="Infinity" text="Transactions" />
        <Button maxWidth="Infinity" text="Reports" />
        <Button maxWidth="Infinity" text="Settings" />
    </VBox>

    <!-- Main Content -->
    <VBox layoutX="156.8" layoutY="57.0" prefHeight="365.0" prefWidth="801.0" spacing="15" style="-fx-padding: 10;" AnchorPane.bottomAnchor="43.0" AnchorPane.leftAnchor="157.0" AnchorPane.rightAnchor="6.0" AnchorPane.topAnchor="57.0">

        <!-- Event 1 & 2: Access module & input -->
        <HBox spacing="10">
            <Label prefHeight="26.0" prefWidth="87.0" text="Select Module:" />
            <ComboBox fx:id="moduleComboBox" prefWidth="200" />
            <Label prefHeight="26.0" prefWidth="93.0" text="Transaction ID:" />
            <TextField fx:id="transactionField" promptText="Enter Transaction ID" />
        </HBox>

        <!-- Event 3 & 4: Validate & Verify -->
        <HBox prefHeight="3.0" prefWidth="545.0" spacing="10">
            <Button fx:id="validateBtn" text="Validate Input" />
            <Button fx:id="verifyBtn" text="Verify Authenticity" />
        </HBox>

        <!-- Event 5: Process Data -->
        <HBox spacing="10">
            <Button fx:id="processBtn" text="Process Data" />
            <ProgressIndicator fx:id="progressIndicator" visible="false" />
        </HBox>

        <!-- Event 6: Display Output -->
        <TableView fx:id="reportTable" prefHeight="222.0" prefWidth="691.0" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn prefWidth="111.19996011257172" text="Transaction ID" />
                <TableColumn prefWidth="87.20001983642578" text="Amount" />
                <TableColumn prefWidth="73.59996032714844" text="Status" />
                <TableColumn minWidth="0.0" prefWidth="120.00003051757812" text="Date" />
                <TableColumn prefWidth="214.39993286132812" text="Risk Level" />
            </columns>
        </TableView>

    </VBox>

    <!-- Status Bar -->
    <HBox layoutX="166.0" layoutY="445.0" prefHeight="27.0" prefWidth="781.0" style="-fx-background-color: #dcdcdc; -fx-padding: 5;" AnchorPane.bottomAnchor="16.0" AnchorPane.leftAnchor="166.0" AnchorPane.rightAnchor="17.0">
        <Label fx:id="statusLabel" text="Ready" />
    </HBox>

</AnchorPane>
