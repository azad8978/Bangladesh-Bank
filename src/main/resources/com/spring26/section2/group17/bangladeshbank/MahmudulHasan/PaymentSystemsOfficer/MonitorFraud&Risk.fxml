<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.spring26.section2.group17.bangladeshbank.MahmudulHasan.PaymentSystemsOfficer.MonitorFraudRiskController">
    <!-- Header -->
    <HBox spacing="10" style="-fx-background-color: #2E8B57; -fx-padding: 10;" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">
        <Label prefHeight="26.0" prefWidth="502.0" style="-fx-text-fill: white;" text="                           ⚠️ Banking Fraud  Risk Monitoring System">
            <font>
                <Font size="20" />
            </font>
        </Label>
        <Pane HBox.hgrow="ALWAYS" />
        <Button text="Logout" />
    </HBox>

    <!-- Sidebar -->
    <VBox prefWidth="200" spacing="15" style="-fx-background-color: #f0f0f0; -fx-padding: 10;" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.topAnchor="50">
        <Label style="-fx-font-weight: bold;" text="Navigation" />
        <Button maxWidth="Infinity" text="Dashboard" />
        <Button maxWidth="Infinity" text="Transactions" />
        <Button maxWidth="Infinity" text="Reports" />
        <Button maxWidth="Infinity" text="Settings" />
    </VBox>

    <!-- Main Content -->
    <VBox layoutX="211.0" prefHeight="336.0" prefWidth="379.0" spacing="15" style="-fx-padding: 10;" AnchorPane.bottomAnchor="14.0" AnchorPane.leftAnchor="211.0" AnchorPane.rightAnchor="10" AnchorPane.topAnchor="50">

        <!-- Event 1 & 2: Access module & input -->
        <HBox spacing="10">
            <Label text="Select Module:" />
            <ComboBox fx:id="moduleComboBox" prefWidth="200" />
            <Label text="Transaction ID:" />
            <TextField fx:id="transactionField" promptText="Enter Transaction ID" />
        </HBox>

        <!-- Event 3 & 4: Validate & Verify -->
        <HBox spacing="10">
            <Button fx:id="validateBtn" text="Validate Input" />
            <Button fx:id="verifyBtn" text="Verify Authenticity" />
        </HBox>

        <!-- Event 5: Process Data -->
        <HBox spacing="10">
            <Button fx:id="processBtn" text="Process Data" />
            <ProgressIndicator fx:id="progressIndicator" visible="false" />
        </HBox>

        <!-- Event 6: Display Output -->
        <TableView fx:id="reportTable" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn prefWidth="150" text="Transaction ID" />
                <TableColumn prefWidth="100" text="Amount" />
                <TableColumn prefWidth="100" text="Status" />
                <TableColumn prefWidth="150" text="Date" />
                <TableColumn prefWidth="100" text="Risk Level" />
            </columns>
        </TableView>

    </VBox>

    <!-- Status Bar -->
    <HBox layoutX="220.0" layoutY="357.0" prefHeight="17.0" prefWidth="360.0" style="-fx-background-color: #dcdcdc; -fx-padding: 5;" AnchorPane.bottomAnchor="16.0" AnchorPane.leftAnchor="220.0" AnchorPane.rightAnchor="20.0">
        <Label fx:id="statusLabel" text="Ready" />
    </HBox>

</AnchorPane>
