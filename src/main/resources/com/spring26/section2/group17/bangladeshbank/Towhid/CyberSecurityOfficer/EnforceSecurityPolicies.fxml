<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.spring26.section2.group17.bangladeshbank.Towhid.CyberSecurityOfficer.EnforceSecurityPoliciesController"
            prefHeight="550.0" prefWidth="850.0">

    <children>

        <!-- Title -->
        <Label layoutX="270.0" layoutY="20.0"
               text="Enforce Security Policies"
               style="-fx-font-size:18px; -fx-font-weight:bold;" />

        <!-- Policy Table -->
        <Label layoutX="50.0" layoutY="80.0"
               text="Available Policies:"
               style="-fx-font-weight:bold;" />

        <TableView fx:id="policyTable"
                   layoutX="50.0"
                   layoutY="110.0"
                   prefWidth="750.0"
                   prefHeight="250.0">

            <columns>
                <TableColumn text="Policy Name" prefWidth="250.0" />
                <TableColumn text="Status" prefWidth="150.0" />
                <TableColumn text="Last Updated" prefWidth="350.0" />
            </columns>

        </TableView>

        <!-- Enforce Button -->
        <Button fx:id="enforceButton"
                layoutX="350.0"
                layoutY="380.0"
                text="Enforce Policy"
                prefWidth="160.0" />

        <!-- Status Output -->
        <Label layoutX="50.0" layoutY="430.0"
               text="System Log:"
               style="-fx-font-weight:bold;" />

        <TextArea fx:id="statusArea"
                  layoutX="50.0"
                  layoutY="460.0"
                  prefWidth="750.0"
                  prefHeight="70.0"
                  editable="false" />

    </children>

</AnchorPane>