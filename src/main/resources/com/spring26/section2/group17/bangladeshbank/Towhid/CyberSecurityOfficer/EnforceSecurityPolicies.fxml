<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="550.0" prefWidth="850.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.spring26.section2.group17.bangladeshbank.Towhid.CyberSecurityOfficer.EnforceSecurityPoliciesController">

    <children>

        <!-- Title -->
        <Label layoutX="270.0" layoutY="20.0" style="-fx-font-size:18px; -fx-font-weight:bold;" text="Enforce Security Policies" />

        <!-- Policy Table -->
        <Label layoutX="50.0" layoutY="80.0" style="-fx-font-weight:bold;" text="Available Policies:" />

        <TableView fx:id="policyTable" layoutX="50.0" layoutY="110.0" prefHeight="250.0" prefWidth="750.0">

            <columns>
                <TableColumn fx:id="PolicyAP" prefWidth="250.0" text="Policy Name" />
                <TableColumn fx:id="StatusAP" prefWidth="150.0" text="Status" />
                <TableColumn fx:id="LastAP" prefWidth="350.0" text="Last Updated" />
            </columns>

        </TableView>

        <!-- Enforce Button -->
        <Button layoutX="350.0" layoutY="380.0" onAction="#enforccepolicy" prefWidth="160.0" text="Enforce Policy" />

        <!-- Status Output -->
        <Label layoutX="50.0" layoutY="430.0" style="-fx-font-weight:bold;" text="System Log:" />

        <TextArea fx:id="statusArea" editable="false" layoutX="50.0" layoutY="460.0" prefHeight="70.0" prefWidth="750.0" />
      <Button layoutX="604.0" layoutY="380.0" mnemonicParsing="false" onAction="#ButtonOA" text="BackButton" />

    </children>

</AnchorPane>
