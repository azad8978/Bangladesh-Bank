<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.LineChart?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.spring26.section2.group17.bangladeshbank.MahmudulHasan.PaymentSystemsOfficer.GeneratePaymentPerformanceReportsController">

    <!-- Top Header -->
    <HBox prefHeight="50.0" spacing="20" style="-fx-background-color: #2C3E50;" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
        <children>
            <Label prefHeight="23.0" prefWidth="377.0" style="-fx-text-fill: white; -fx-font-size: 18px;" text="                            Payment Reports Module" />
            <Region HBox.hgrow="ALWAYS" />
            <Button text="Export" />
            <Button text="Refresh" />
            <Button text="Help" />
        </children>
        <padding>
            <Insets bottom="10" left="10" right="10" top="10" />
        </padding>
    </HBox>

    <!-- Left Sidebar -->
    <VBox prefWidth="250.0" spacing="10" style="-fx-background-color: #ECF0F1;" AnchorPane.bottomAnchor="50.0" AnchorPane.leftAnchor="0.0" AnchorPane.topAnchor="50.0">
        <children>
            <Label text="Filters" />
            <DatePicker />
            <DatePicker />
            <ComboBox promptText="Type" />
            <ComboBox promptText="Status" />
            <TextField promptText="Customer ID" />
            <Button text="Apply" />
            <Button text="Reset" />
        </children>
        <padding>
            <Insets bottom="10" left="10" right="10" top="10" />
        </padding>
    </VBox>

    <!-- Center Table -->
    <VBox spacing="10" AnchorPane.bottomAnchor="50.0" AnchorPane.leftAnchor="250.0" AnchorPane.rightAnchor="350.0" AnchorPane.topAnchor="50.0">
        <children>
            <Label text="Transactions" />
            <TableView>
                <columns>
                    <TableColumn text="ID" />
                    <TableColumn text="Date" />
                    <TableColumn text="Amount" />
                    <TableColumn text="Status" />
                </columns>
            </TableView>
        </children>
        <padding>
            <Insets bottom="10" left="10" right="10" top="10" />
        </padding>
    </VBox>

    <!-- Right Panel -->
    <VBox prefWidth="350.0" spacing="10" style="-fx-background-color: #F4F6F7;" AnchorPane.bottomAnchor="50.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="50.0">
        <children>
            <Label text="Analytics" />
            <LineChart title="Trend">
                <xAxis>
                    <CategoryAxis />
                </xAxis>
                <yAxis>
                    <NumberAxis />
                </yAxis>
            </LineChart>
            <Label text="Actions" />
            <Button text="Verify" />
            <Button text="Process" />
        </children>
        <padding>
            <Insets bottom="10" left="10" right="10" top="10" />
        </padding>
    </VBox>

    <!-- Footer -->
    <HBox prefHeight="50.0" spacing="20" style="-fx-background-color: #2C3E50;" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">
        <children>
            <Label style="-fx-text-fill: white;" text="Total: 0" />
            <Region HBox.hgrow="ALWAYS" />
            <Label style="-fx-text-fill: white;" text="Time: --:--" />
        </children>
        <padding>
            <Insets bottom="10" left="10" right="10" top="10" />
        </padding>
    </HBox>

</AnchorPane>
