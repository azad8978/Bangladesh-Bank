<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="524.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.spring26.section2.group17.bangladeshbank.MahmudulHasan.PaymentSystemsOfficer.OverseePaymentGatewayOperationsController">
    <children>

        <!-- Background -->
        <VBox prefHeight="389.0" prefWidth="600.0" spacing="15" style="-fx-background-color: linear-gradient(to bottom, #E3F2FD, #FFFFFF); -fx-padding:20;" AnchorPane.bottomAnchor="11.0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">

            <!-- Header -->
            <Label prefHeight="26.0" prefWidth="453.0" style="-fx-font-size:20px; -fx-font-weight:bold; -fx-text-fill:#1976D2;" text="                                 💳 Payment Gateway Operations" />

            <!-- Filter Card -->
            <VBox spacing="10" style="-fx-background-color:white; -fx-padding:15; -fx-background-radius:10; -fx-effect:dropshadow(gaussian, lightgray, 10,0,0,2);">

                <Label style="-fx-font-size:14px; -fx-font-weight:bold;" text="Filter Transactions" />

                <HBox spacing="10">
                    <TextField fx:id="txtTransactionId" promptText="Transaction ID" />
                    <ComboBox fx:id="cmbStatus" promptText="Status" />
                    <Button onAction="#handleSearch" style="-fx-background-color:#4CAFEF; -fx-text-fill:white;" text="Search" />
                </HBox>
            </VBox>

            <!-- Table Card -->
            <VBox spacing="10" style="-fx-background-color:white; -fx-padding:15; -fx-background-radius:10; -fx-effect:dropshadow(gaussian, lightgray, 10,0,0,2);">

                <Label style="-fx-font-size:14px; -fx-font-weight:bold;" text="Transaction Records" />

                <TableView fx:id="transactionTable" prefHeight="246.0" prefWidth="530.0">
                    <columns>
                        <TableColumn text="ID" />
                        <TableColumn text="User" />
                        <TableColumn text="Amount" />
                        <TableColumn text="Status" />
                    </columns>
                </TableView>
            </VBox>

            <!-- Action Buttons -->
            <HBox spacing="15">

                <Button onAction="#handleValidate" style="-fx-background-color:#FFC107; -fx-text-fill:black;" text="✔ Validate" />

                <Button onAction="#handleVerify" style="-fx-background-color:#4CAF50; -fx-text-fill:white;" text="🔐 Verify" />

                <Button onAction="#handleProcess" style="-fx-background-color: blue; -fx-text-fill: white;" text="⚙ Process" />

            </HBox>
         <Button mnemonicParsing="false" onAction="#backButton" style="-fx-background-color: Red; -fx-text-fill: white;" text="Back">
            <font>
               <Font name="System Bold" size="12.0" />
            </font>
         </Button>

        </VBox>

    </children>

</AnchorPane>
