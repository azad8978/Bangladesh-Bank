<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="550.0" prefWidth="850.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.spring26.section2.group17.bangladeshbank.Towhid.CyberSecurityOfficer.ReviewSystemLogsController">

    <children>

        <!-- Title -->
        <Label layoutX="300.0" layoutY="20.0" style="-fx-font-size:18px; -fx-font-weight:bold;" text="System Logs Review" />

        <!-- Filter Section -->
        <Label layoutX="50.0" layoutY="80.0" text="Log Type:" />
        <ComboBox fx:id="logTypeComboBox" layoutX="130.0" layoutY="75.0" prefWidth="150.0" />

        <Label layoutX="300.0" layoutY="80.0" text="Source:" />
        <TextField fx:id="sourceField" layoutX="360.0" layoutY="75.0" prefWidth="150.0" />

        <Label layoutX="530.0" layoutY="80.0" text="Date:" />
        <DatePicker fx:id="datePicker" layoutX="580.0" layoutY="75.0" />

        <!-- Filter Button -->
        <Button layoutX="580.0" layoutY="113.0" onAction="#applyfilter" text="Apply Filter" />

        <!-- Table -->
        <Label layoutX="50.0" layoutY="130.0" style="-fx-font-weight:bold;" text="System Logs:" />

        <TableView fx:id="logTable" layoutX="50.0" layoutY="160.0" prefHeight="300.0" prefWidth="750.0">

            <columns>
                <TableColumn fx:id="loginSL" prefWidth="100.0" text="Log ID" />
                <TableColumn fx:id="sourceSL" prefWidth="150.0" text="Source" />
                <TableColumn fx:id="actionSL" prefWidth="250.0" text="Action" />
                <TableColumn fx:id="timeSL" prefWidth="250.0" text="Timestamp" />
            </columns>

        </TableView>

        <!-- Status -->
        <Label layoutX="50.0" layoutY="480.0" style="-fx-font-weight:bold;" text="Status:" />

        <TextArea fx:id="statusArea" editable="false" layoutX="110.0" layoutY="470.0" prefHeight="60.0" prefWidth="690.0" />
      <Button layoutX="675.0" layoutY="35.0" mnemonicParsing="false" onAction="#ButtonOA" text="BackButton" />

    </children>

</AnchorPane>
